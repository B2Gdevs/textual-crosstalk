# conduit_proj — env example
# Copy to .env.local and fill in real values. .env.local is gitignored.

# --- Required for Part 1 ---

# Deepgram (speech-to-text) — get from console.deepgram.com
DEEPGRAM_API_KEY=

# OpenRouter (LLM, OpenAI-compatible router) — get from openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Groq (LLM fallback if OpenRouter rate-limits)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ElevenLabs (text-to-speech) — get from elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Optional fallbacks ---

# OpenAI (LLM fallback if Groq rate-limits)
OPENAI_API_KEY=

# Anthropic (LLM fallback)
ANTHROPIC_API_KEY=

# Cerebras (LLM, even faster than Groq, newer)
CEREBRAS_API_KEY=

# --- Runtime config ---

# Path to append-only char timeline (JSONL)
CONDUIT_CHAR_LOG=./data/chars.jsonl

# Audio sample rate (16000 recommended for Deepgram)
CONDUIT_SAMPLE_RATE=16000
